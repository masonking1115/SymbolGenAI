.DS_Store
*.log
.env
.env.local

# Editor/agent local state
.claude/settings.local.json
.vscode/
.idea/

# KiCad source tree (symlinked from ~/Downloads/kicad/)
/kicad

# KiCad transient/per-user files (lock files, local prefs, regenerated exports)
~*.lck
*.kicad_prl
*/render/
fp-info-cache

# KiCad per-project auto-versioning
.history/

# Office temp lock files
~$*

# Python bytecode cache
__pycache__/
*.pyc

# Locally-exported KiCad PDFs (regenerated on demand)
test1/kicad/*.pdf

# Simulation runtime artifacts (caches, iter counters, ngspice outputs)
test1/sim/cache/
test1/sim/results/

# Review pipeline transient output
test1/review/findings.json

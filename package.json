{
  "name": "symbol-library-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI Copilot for EDA Symbol Library Management - Schematic Editor MVP",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env ELECTRON_IS_DEV=1 ELECTRON_RUN_AS_NODE= electron .",
    "dev:web": "vite",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:electron && npm run build:renderer",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json"
  },
  "dependencies": {
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "wait-on": "^7.2.0"
  }
}